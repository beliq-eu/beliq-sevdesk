# beliq-sevdesk worker configuration. Every setting is read from the environment;
# a few also have a flag that overrides it (noted below).

# --- Required credentials ---------------------------------------------------

# sevDesk API token (Settings -> Advanced -> API). A single account-wide token;
# it never leaves this environment. Or pass --sevdesk-token.
SEVDESK_API_TOKEN=

# beliq API key (dashboard -> API Keys). The @beliq/sdk reads no environment of
# its own, so the worker owns this. Or pass --api-key.
BELIQ_API_KEY=

# --- What to do with each invoice -------------------------------------------

# Comma-separated beliq convert target formats. Each polled invoice's XML is
# converted to every target and written to the output dir. Leave empty to run
# validation-only (no conversion, no files written). Or pass --target-format.
# Allowed: cii, ubl, zugferd, facturx, xrechnung, peppol-bis
SEVDESK_TARGET_FORMATS=peppol-bis

# Factur-X / ZUGFeRD profile, used only when a target is facturx or zugferd.
# Allowed: basicwl, en16931, extended, extended-ctc-fr
SEVDESK_TARGET_PROFILE=

# --- What to poll -----------------------------------------------------------

# Which sevDesk invoices to poll: Draft, Open, or Paid (or the numeric code
# 100 / 200 / 1000). Or pass --status. Default: Open.
SEVDESK_INVOICE_STATUS=Open

# Only fetch invoices dated within this many days back (bounds the query so a
# poll stays cheap). 0 disables the date filter. Or pass --poll-window-days.
SEVDESK_POLL_WINDOW_DAYS=30

# --- Where state and output live --------------------------------------------

# The persisted high-water-mark file (the last processed invoice id). Or pass
# --state. Default: .beliq-sevdesk-state.json
SEVDESK_STATE_FILE=.beliq-sevdesk-state.json

# Directory the converted documents are written to. Created if missing. Or pass
# --output. Default: ./out
SEVDESK_OUTPUT_DIR=./out

# --- Loop and networking (advanced) -----------------------------------------

# Seconds between polls when running as a daemon (ignored with --once).
SEVDESK_POLL_INTERVAL_SECONDS=300

# Page size for the sevDesk invoice listing.
SEVDESK_PAGE_SIZE=100

# Retries on a sevDesk 429 / 5xx / network error, with exponential backoff.
SEVDESK_MAX_RETRIES=4

# Override only for a sevDesk mock or a future API version.
SEVDESK_BASE_URL=https://api.sevdesk.de/api/v1

# Override only for a self-hosted beliq deployment.
BELIQ_BASE_URL=https://api.beliq.eu

# How the beliq key is sent: header (X-API-Key, default) or bearer.
BELIQ_AUTH=header

# --- Notify webhook (optional) ----------------------------------------------

# POST a JSON poll report to this URL after a poll. Best-effort: a failing
# webhook is logged (host only) and never changes the exit code. Or pass
# --notify-webhook. Leave empty to disable.
SEVDESK_NOTIFY_WEBHOOK=

# When to notify: failure (default, only when an invoice fails) or always (a
# heartbeat after every poll, best for --once / cron).
SEVDESK_NOTIFY_ON=failure
